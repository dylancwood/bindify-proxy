name = "your-worker-name"
main = "src/index.ts"
compatibility_date = "2024-12-01"
account_id = "YOUR_CLOUDFLARE_ACCOUNT_ID"

# Required environment variables (set in .dev.vars or Workers dashboard):
# ADMIN_URL - Admin portal URL (e.g. https://app.yourdomain.com)
# CLERK_PUBLISHABLE_KEY - Clerk publishable key (JWKS URL is derived from this automatically)
# CLERK_JWKS_URL - (optional) Clerk JWKS URL override; if omitted, derived from CLERK_PUBLISHABLE_KEY
# STRIPE_SECRET_KEY - Stripe secret API key
# STRIPE_WEBHOOK_SECRET - Stripe webhook signing secret
# STRIPE_PRICE_CONNECTIONS - Stripe price ID for connections (graduated pricing)
# CLERK_SECRET_KEY - Clerk secret key (for account deletion)
# MANAGED_ENCRYPTION_KEYS - JSON array of master keys for managed token encryption
# Format: [{"key":"<hex>"},{"key":"<hex>"}]  (fingerprints computed at parse time)
# Generate a key with: openssl rand -hex 32
# Falls back to MANAGED_ENCRYPTION_MASTER_KEY (single key as v1) during transition
# MANAGED_ENCRYPTION_MASTER_KEY - Legacy single master key (deprecated, use MANAGED_ENCRYPTION_KEYS)
# LINEAR_CLIENT_ID - Linear OAuth client ID
# LINEAR_CLIENT_SECRET - Linear OAuth client secret
# TODOIST_CLIENT_ID - Todoist OAuth client ID
# TODOIST_CLIENT_SECRET - Todoist OAuth client secret
# ATLASSIAN_CLIENT_ID - Atlassian OAuth client ID
# ATLASSIAN_CLIENT_SECRET - Atlassian OAuth client secret
# NOTION_CLIENT_ID - Notion OAuth client ID
# NOTION_CLIENT_SECRET - Notion OAuth client secret
# GITHUB_CLIENT_ID - GitHub OAuth client ID
# GITHUB_CLIENT_SECRET - GitHub OAuth client secret
# FIGMA_CLIENT_ID - Figma OAuth client ID
# FIGMA_CLIENT_SECRET - Figma OAuth client secret
# SMTP2GO_API_KEY - SMTP2GO API key for email notifications
# ADMIN_NOTIFICATION_EMAIL - Email address for admin notifications
# OPS_NOTIFICATION_ORIGIN_EMAIL - Sender address for ops notifications

[[kv_namespaces]]
binding = "KV"
id = "YOUR_KV_NAMESPACE_ID"

[observability]
enabled = false
head_sampling_rate = 1

[observability.logs]
enabled = true
head_sampling_rate = 1
persist = true
invocation_logs = true

[observability.traces]
enabled = true
persist = true
head_sampling_rate = 1

[[d1_databases]]
binding = "DB"
database_name = "your-db-name"
database_id = "YOUR_D1_DATABASE_ID"
migrations_dir = "migrations"

[[routes]]
pattern = "api.yourdomain.com"
custom_domain = true

[vars]
ADMIN_URL = "https://app.yourdomain.com"
ADMIN_NOTIFICATION_EMAIL = "admin@yourdomain.com"
OPS_NOTIFICATION_ORIGIN_EMAIL = "Notifications <notifications@yourdomain.com>"
CLERK_PUBLISHABLE_KEY = "YOUR_CLERK_PUBLISHABLE_KEY"
IP_ALLOWLIST = ""
SECRET_ENV_PREFIX = "live"

[triggers]
# Cron triggers:
# * * * * *           - Key rotation processing and orphan fingerprint detection (every minute)
# 21 5 * * *          - Daily token refresh
# 0 2,8,14,20 * * *   - Keepalive checks (every 6 hours)
# 0 4,10,16,22 * * *  - Consistency checks (every 6 hours)
crons = ["* * * * *", "21 5 * * *", "0 2,8,14,20 * * *", "0 4,10,16,22 * * *"]

# Optional: staging environment
# [env.staging]
# name = "your-worker-staging"
# workers_dev = true
#
# [[env.staging.routes]]
# pattern = "api.staging.yourdomain.com"
# custom_domain = true
#
# [env.staging.vars]
# ADMIN_URL = "https://app.staging.yourdomain.com"
# CLERK_PUBLISHABLE_KEY = "YOUR_STAGING_CLERK_PUBLISHABLE_KEY"
# SECRET_ENV_PREFIX = "stg"
#
# [[env.staging.kv_namespaces]]
# binding = "KV"
# id = "YOUR_STAGING_KV_NAMESPACE_ID"
#
# [[env.staging.d1_databases]]
# binding = "DB"
# database_name = "your-db-staging"
# database_id = "YOUR_STAGING_D1_DATABASE_ID"
# migrations_dir = "migrations"
